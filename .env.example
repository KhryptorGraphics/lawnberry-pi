# LawnBerry Pi environment configuration (example)
# Copy to .env and fill in your values.

# Optional: additional domains (comma-separated)
ALT_DOMAINS=
# Optional: Cloudflare token for DNS-01 challenges (Zone:DNS:Edit on your zone)
CLOUDFLARE_API_TOKEN=
# Primary domain used for HTTPS certificates
LB_DOMAIN=example.com
# Contact email for Let's Encrypt registration and expiry notices
LETSENCRYPT_EMAIL=you@example.com

# Local service ports
BACKEND_PORT=8081
FRONTEND_PORT=3000

# --- RTK / NTRIP corrections -------------------------------------------------
# Required when gps_ntrip_enabled=true so the backend can stream RTCM data
# from a caster to the ZED-F9P receiver.
NTRIP_HOST=
NTRIP_MOUNTPOINT=
NTRIP_PASSWORD=
NTRIP_PORT=
NTRIP_USERNAME=

# Serial link to the rover GPS.
# LC29H uses /dev/ttyAMA0 at 115200 baud (UART)
# ZED-F9P uses /dev/ttyACM0 or /dev/ttyACM1 (USB)
NTRIP_SERIAL_BAUD=115200
NTRIP_SERIAL_DEVICE=/dev/ttyAMA0

# Optional: Provide a static GGA sentence when the rover is stationary.
NTRIP_GGA_ALT=
NTRIP_GGA_INTERVAL=
NTRIP_GGA_LAT=
NTRIP_GGA_LON=

# --- ACME / TLS (certbot-backed) --------------------------------------------
# Use the Let's Encrypt staging environment (1) until you are ready to issue a
# real certificate (0). Staging avoids production rate limits.
ACME_STAGING=1
# Webroot served on port 80 whose /.well-known/acme-challenge/ answers HTTP-01.
ACME_WEBROOT=/var/www
# certbot config/account/live state directory.
ACME_LE_DIR=/etc/letsencrypt
# Path to the certbot binary (auto-detected if unset).
# ACME_CERTBOT_BIN=/usr/bin/certbot

# --- Auth hardening ---------------------------------------------------------
# Login attempt rate limit (per client) and failed-attempt lockout.
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_WINDOW=60
AUTH_LOCKOUT_FAILURES=5
AUTH_LOCKOUT_SECONDS=30

# --- Google OAuth (optional) ------------------------------------------------
# When Google OAuth is enabled, google-auth must be installed and the token is
# verified server-side (login fails closed if verification is unavailable).

# --- Paths (override on-device) ---------------------------------------------
# LAWNBERRY_DATA_DIR=/apps/lawnberry-pi/data
# LAWNBERRY_DOCS_DIR=/apps/lawnberry-pi/docs

# --- Thor training-data sync ------------------------------------------------
# Pi side: where to upload recorded mowing sessions for training.
THOR_BASE_URL=http://thor.local:8000
THOR_API_KEY=
# Thor side (ingest server): where received sessions are written + bind address.
THOR_INGEST_DIR=./data/thor_ingest
THOR_INGEST_HOST=0.0.0.0
THOR_INGEST_PORT=8000
